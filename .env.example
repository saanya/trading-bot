# Bybit API — Account #1 (MTF Trend Scalper)
BYBIT_API_KEY_MTF=your_mtf_api_key
BYBIT_API_SECRET_MTF=your_mtf_api_secret
BYBIT_TESTNET=true

# Bybit API — Account #2 (EMA Scalper)
BYBIT_API_KEY_SCALP=your_scalp_api_key
BYBIT_API_SECRET_SCALP=your_scalp_api_secret

# Bybit API — Account #3 (ORB Breakout)
BYBIT_API_KEY_ORB=your_orb_api_key
BYBIT_API_SECRET_ORB=your_orb_api_secret

# Trading pair
SYMBOL=BTCUSDT

# Timeframe for entries (1, 3, 5, 15, 30, 60, 120, 240, 360, 720, D, W, M)
TIMEFRAME=15

# Position size in USDT
POSITION_SIZE=100

# Leverage
LEVERAGE=10

# Dry run mode (true = no real orders, just logs)
DRY_RUN=true

# Log level (debug, info, warn, error)
LOG_LEVEL=info
