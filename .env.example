# Bybit API (https://www.bybit.com/app/user/api-management)
BYBIT_API_KEY=your_api_key
BYBIT_API_SECRET=your_api_secret
BYBIT_TESTNET=true

# Trading pair
SYMBOL=BTCUSDT

# Timeframe for entries (1, 3, 5, 15, 30, 60, 120, 240, 360, 720, D, W, M)
TIMEFRAME=15

# Position size in USDT
POSITION_SIZE=100

# Leverage
LEVERAGE=10

# Dry run mode (true = no real orders, just logs)
DRY_RUN=true

# Log level (debug, info, warn, error)
LOG_LEVEL=info
